#!/bin/bash
# Description: Permanently deletes ALL NetworkManager connections of type 'vpn'.
# Usage: sudo nuke-vpn-configs

# Check for root permissions
if [ "$EUID" -ne 0 ]; then
    echo "Please run as root."
    exit 1
fi

# Retrieve UUIDs of all connections with type 'vpn'
# -t: Terse output (colon separated)
# -f: Fields (UUID, TYPE)
vpn_uuids=$(nmcli -t -f UUID,TYPE connection show | grep ":vpn$" | cut -d: -f1)

if [ -z "$vpn_uuids" ]; then
    echo "No VPN connections found."
    exit 0
fi

echo "The following VPN connections will be permanently deleted:"
nmcli -p -f NAME,TYPE,UUID connection show | grep "vpn"
echo ""

# Safety Prompt
read -p "Are you sure you want to delete ALL these connections? (y/N): " confirm
if [[ "$confirm" != [yY] && "$confirm" != [yY][eE][sS] ]]; then
    echo "Operation aborted."
    exit 0
fi

# Delete connections by UUID
echo "$vpn_uuids" | xargs -r nmcli connection delete
echo "All VPN configurations have been removed."
