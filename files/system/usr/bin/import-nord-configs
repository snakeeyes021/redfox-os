#!/bin/bash
# Description: Automates downloading and importing NordVPN OVPN configurations.
#              Updates GNOME Quick Settings "MRU" (Most Recently Used) list
#              by briefly triggering connection attempts on the top 8 items.
# Usage: sudo import-nord-configs
#              Headless execution. Relies on redfox-enforce-secrets for validation.

# Check for root privileges
if [ "$EUID" -ne 0 ]; then
    echo "Error: This script must be run as root."
    exit 1
fi

# Check for required dependencies
for cmd in nmcli curl timeout tac grep; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "Error: $cmd is required but not installed."
        exit 1
    fi
done

# --- 1. STATE & IPC EVALUATION ---
IPC_FILE="/tmp/redfox-force-vpn-import"
FORCE_IMPORT=false

# Check for the ephemeral "GO" signal (Consume and Destroy)
if [ -f "$IPC_FILE" ]; then
    rm -f "$IPC_FILE"
    FORCE_IMPORT=true
fi

SECRETS_DIR="/var/home/$(logname)/.config/redfox"
CONFIG_FILE="$SECRETS_DIR/nordvpn-connections.txt"
SECRETS_FILE="$SECRETS_DIR/secrets.env"

if [ ! -s "$CONFIG_FILE" ] || [ ! -s "$SECRETS_FILE" ]; then
    exit 0 # Silent skip, missing files
fi

source "$SECRETS_FILE"
if [ -z "$VPN_USER" ] || [ -z "$VPN_PASS" ]; then
    exit 0 # Silent skip, empty variables
fi

# The Gate: Are they validated, OR did the user force it?
if [ "$FORCE_IMPORT" = false ] && [ "${VPN_VALIDATED:-false}" != "true" ]; then
    exit 0 # Silent skip, unvalidated and not forced
fi

# --- 2. IMPORT LOGIC ---
TEMP_DIR=$(mktemp -d)
trap 'rm -rf "$TEMP_DIR"' EXIT

echo "================================================================="
echo "                RedFoxOS NordVPN Configuration                   "
echo "================================================================="

echo "Phase 0: Cleaning up duplicate connections..."
while IFS= read -r line || [ -n "$line" ]; do
    [[ -z "$line" || "$line" =~ ^# ]] && continue
    if [[ "$line" =~ ^(.*)\ -\ (https://.*)$ ]]; then
        description="${BASH_REMATCH[1]}"
        # Get all UUIDs for this name
        uuids=$(nmcli -t -f UUID,NAME connection show | grep ":${description}$" | cut -d: -f1 || true)
        count=$(echo "$uuids" | grep -v '^$' | wc -l)
        
        if [ "$count" -gt 1 ]; then
            echo "  [FIX] Removing $count duplicates for: $description"
            # Keep the first one, delete the rest
            echo "$uuids" | tail -n +2 | while read -r extra_uuid; do
                nmcli connection delete uuid "$extra_uuid" >/dev/null 2>&1
            done
        fi
    fi
done < "$CONFIG_FILE"

echo -e "\nPhase 1: Importing missing configurations..."
while IFS= read -r line || [ -n "$line" ]; do
    [[ -z "$line" || "$line" =~ ^# ]] && continue

    if [[ "$line" =~ ^(.*)\ -\ (https://.*)$ ]]; then
        description="${BASH_REMATCH[1]}"
        url="${BASH_REMATCH[2]}"
        safe_filename=$(echo "$description" | tr -dc 'a-zA-Z0-9 -')
        filepath="$TEMP_DIR/$safe_filename.ovpn"

        if nmcli connection show "$description" >/dev/null 2>&1; then
             echo "  [SKIP] $description (already exists)"
             continue
        fi

        echo "  Downloading: $description..."
        if curl -sS -L -o "$filepath" "$url"; then
            nmcli connection import type openvpn file "$filepath" >/dev/null 2>&1
            if [ $? -eq 0 ]; then
                conn_uuid=$(nmcli -t -f UUID,FILENAME connection show | grep "$filepath" | cut -d: -f1 | head -n 1)
                if [ -n "$conn_uuid" ]; then
                    nmcli connection modify "$conn_uuid" -vpn.data connection-type 2>/dev/null || true
                    nmcli connection modify "$conn_uuid" +vpn.data connection-type=password-tls
                    nmcli connection modify "$conn_uuid" +vpn.data username="$VPN_USER"
                    nmcli connection modify "$conn_uuid" +vpn.secrets password="$VPN_PASS"
                    nmcli connection modify "$conn_uuid" +vpn.data password-flags=0
                    nmcli connection modify "$conn_uuid" connection.id "$description"
                    echo "  [OK] Imported: $description"
                fi
            else
                echo "  [ERROR] Import failed for $description"
            fi
        else
            echo "  [ERROR] Download failed for $url"
        fi
    fi
done < "$CONFIG_FILE"

echo -e "\nPhase 2: Enforcing sort order (Touching Top 8)..."
for i in 1 2; do
    grep " - https" "$CONFIG_FILE" | head -n 8 | tac | while read -r line; do
        if [[ "$line" =~ ^(.*)\ -\ https://.*$ ]]; then
            conn_name="${BASH_REMATCH[1]}"
            echo -n "  Touching: $conn_name... "
            timeout 5s nmcli connection up "$conn_name" >/dev/null 2>&1
            nmcli connection down "$conn_name" >/dev/null 2>&1
            echo "Done."
        fi
    done
done

echo -e "\nSuccess. NordVPN setup complete and Top 8 connections are pinned."
